generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum Gender {
  MALE
  FEMALE
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  PROBATION
  RESIGNED
  TERMINATED
}

enum SalaryType {
  MONTHLY
  DAILY
  HOURLY
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  DROPPED_OUT
}

enum ActivityCategory {
  TEACHING
  DORMITORY
  RELIGIOUS
  ADMINISTRATIVE
  DISCIPLINE
}

enum CompensationType {
  FIXED
  HOURLY
  PER_SESSION
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
}

enum PayrollStatus {
  DRAFT
  GENERATED
  PAID
}

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String    @unique
  name               String
  passwordHash       String    @map("password_hash")
  role               Role      @default(EMPLOYEE)
  refreshTokenHash   String?   @map("refresh_token_hash")
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  employee           Employee?
  validationsReviewed ActivityValidation[] @relation("ValidationReviewer")

  @@map("users")
}

model Employee {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeCode     String           @unique @map("employee_code")
  fullName         String           @map("full_name")
  gender           Gender
  birthDate        DateTime         @map("birth_date") @db.Date
  phoneNumber      String           @map("phone_number")
  address          String
  department       String
  position         String
  joinDate         DateTime         @map("join_date") @db.Date
  employmentStatus EmploymentStatus @default(ACTIVE) @map("employment_status")
  salaryType       SalaryType       @map("salary_type")
  baseSalary       Decimal          @map("base_salary") @db.Decimal(14, 2)
  userId           String?          @unique @map("user_id") @db.Uuid
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  schedules        Schedule[]
  validations      ActivityValidation[]
  attendances      Attendance[]
  payrolls         Payroll[]
  deletedAt        DateTime?        @map("deleted_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at")

  @@index([department])
  @@index([employmentStatus])
  @@index([deletedAt])
  @@map("employees")
}

model Student {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentCode    String        @unique @map("student_code")
  fullName       String        @map("full_name")
  gender         Gender
  birthPlace     String        @map("birth_place")
  birthDate      DateTime      @map("birth_date") @db.Date
  phoneNumber    String?       @map("phone_number")
  address        String
  className      String        @map("class_name")
  academicYear   String        @map("academic_year")
  enrollmentDate DateTime      @map("enrollment_date") @db.Date
  dormitory      String
  roomNumber     String        @map("room_number")
  guardianName   String        @map("guardian_name")
  guardianPhone  String        @map("guardian_phone")
  studentStatus  StudentStatus @default(ACTIVE) @map("student_status")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")

  @@index([className])
  @@index([dormitory])
  @@index([studentStatus])
  @@index([deletedAt])
  @@map("students")
}

model Activity {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityCode       String           @unique @map("activity_code")
  name               String
  description        String?
  category           ActivityCategory
  startTime          DateTime         @map("start_time") @db.Time(0)
  endTime            DateTime         @map("end_time") @db.Time(0)
  location           String
  compensationType   CompensationType @map("compensation_type")
  compensationAmount Decimal          @default(0) @map("compensation_amount") @db.Decimal(14, 2)
  penaltyAmount      Decimal          @default(0) @map("penalty_amount") @db.Decimal(14, 2)
  requiresValidation Boolean          @default(false) @map("requires_validation")
  isRecurring        Boolean          @default(false) @map("is_recurring")
  isActive           Boolean          @default(true) @map("is_active")
  schedules          Schedule[]
  validations        ActivityValidation[]
  attendances        Attendance[]
  deletedAt          DateTime?        @map("deleted_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @default(now()) @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@index([deletedAt])
  @@map("activities")
}

model Schedule {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  description    String?
  employeeId     String         @map("employee_id") @db.Uuid
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  activityId     String         @map("activity_id") @db.Uuid
  activity       Activity       @relation(fields: [activityId], references: [id], onDelete: Restrict)
  startDate      DateTime       @map("start_date") @db.Date
  endDate        DateTime       @map("end_date") @db.Date
  startTime      DateTime       @map("start_time") @db.Time(0)
  endTime        DateTime       @map("end_time") @db.Time(0)
  recurrenceType RecurrenceType @default(NONE) @map("recurrence_type")
  recurrenceDays String[]       @default([]) @map("recurrence_days")
  location       String
  notes          String?
  isActive       Boolean        @default(true) @map("is_active")
  validations    ActivityValidation[]
  attendance     Attendance?
  deletedAt      DateTime?      @map("deleted_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at")

  @@index([employeeId])
  @@index([activityId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("schedules")
}

model ActivityValidation {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId    String           @map("schedule_id") @db.Uuid
  schedule      Schedule         @relation(fields: [scheduleId], references: [id], onDelete: Restrict)
  employeeId    String           @map("employee_id") @db.Uuid
  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  activityId    String           @map("activity_id") @db.Uuid
  activity      Activity         @relation(fields: [activityId], references: [id], onDelete: Restrict)
  status        ValidationStatus @default(PENDING)
  notes         String?
  evidenceUrl   String?          @map("evidence_url")
  submittedAt   DateTime         @default(now()) @map("submitted_at")
  validatedAt   DateTime?        @map("validated_at")
  validatedById String?          @map("validated_by_id") @db.Uuid
  validatedBy   User?            @relation("ValidationReviewer", fields: [validatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at")

  @@index([status])
  @@index([employeeId])
  @@index([activityId])
  @@index([scheduleId])
  @@index([validatedById])
  @@map("activity_validations")
}

model Attendance {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId       String           @map("employee_id") @db.Uuid
  employee         Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  scheduleId       String           @unique @map("schedule_id") @db.Uuid
  schedule         Schedule         @relation(fields: [scheduleId], references: [id], onDelete: Restrict)
  activityId       String           @map("activity_id") @db.Uuid
  activity         Activity         @relation(fields: [activityId], references: [id], onDelete: Restrict)
  attendanceStatus AttendanceStatus @map("attendance_status")
  checkInTime      DateTime         @map("check_in_time")
  checkOutTime     DateTime?        @map("check_out_time")
  lateMinutes      Int              @default(0) @map("late_minutes")
  notes            String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at")

  @@index([employeeId])
  @@index([activityId])
  @@index([attendanceStatus])
  @@index([checkInTime])
  @@map("attendances")
}

model Payroll {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId        String        @map("employee_id") @db.Uuid
  employee          Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  payrollPeriod     String        @map("payroll_period")
  payrollStatus     PayrollStatus @default(GENERATED) @map("payroll_status")
  totalActivities   Int           @default(0) @map("total_activities")
  totalAttendance   Int           @default(0) @map("total_attendance")
  totalCompensation Decimal       @default(0) @map("total_compensation") @db.Decimal(14, 2)
  totalPenalty      Decimal       @default(0) @map("total_penalty") @db.Decimal(14, 2)
  totalLatePenalty  Decimal       @default(0) @map("total_late_penalty") @db.Decimal(14, 2)
  finalAmount       Decimal       @default(0) @map("final_amount") @db.Decimal(14, 2)
  generatedAt       DateTime      @default(now()) @map("generated_at")
  paidAt            DateTime?     @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at")

  @@unique([employeeId, payrollPeriod])
  @@index([employeeId])
  @@index([payrollPeriod])
  @@index([payrollStatus])
  @@map("payrolls")
}
